# SecureAI AI Engine 환경변수 예시
# 실제 값은 .env 파일에 설정하세요 (절대 커밋 금지)

# ── 필수 항목 ────────────────────────────────────────────────────────────────
INTERNAL_API_KEY=change-me-internal-key
CLAUDE_API_KEY=sk-ant-...

# ── Anthropic 모델 설정 ──────────────────────────────────────────────────────
CLAUDE_MODEL=claude-haiku-4-5-20251001

# 스캔 모드별 모델 (Audit: 빠른 비용 효율 / Pipeline: 고품질 정밀 분석)
AUDIT_MODEL=claude-haiku-4-5-20251001
PIPELINE_MODEL=claude-sonnet-4-6

# ── 선택 항목 ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── LangSmith 트레이싱 ───────────────────────────────────────────────────────
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=secureai-agent
LANGCHAIN_TRACING_V2=false

# ── 인프라 ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/1
POSTGRES_URL=postgresql://secureai:secureai@postgres:5432/secureai
POSTGRES_MCP_URL=

# ── MCP 서버 ────────────────────────────────────────────────────────────────
MCP_WORKSPACE_ROOT=/workspace
MCP_SERVER_SCRIPT=/app/mcp_server/dist/index.js

# ── Backend 내부 API ─────────────────────────────────────────────────────────
BACKEND_INTERNAL_URL=http://backend:8080

# ── 임베딩 ──────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_TOP_K=5

# ── OpenTelemetry ────────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=secureai-ai-engine
