# 프론트엔드 로컬 환경변수 예시 — 복사해서 .env.local 로 사용
# cp apps/frontend/.env.local.example apps/frontend/.env.local

# ── Sentry 에러 추적 (선택, TASK-1804) ────────────────────────────────
# Sentry "frontend" 프로젝트의 DSN을 아래 둘 다에 동일하게 설정.
# 비워두면 init 스킵(env-gated) — 로컬/빌드 무해.
NEXT_PUBLIC_SENTRY_DSN=   # 브라우저(client)에서 사용 (public, 번들에 포함됨)
SENTRY_DSN=              # SSR / route handler(server)에서 사용
# ⚠️ 여기엔 반드시 "프론트 프로젝트" DSN만. backend/ai-engine DSN 넣지 말 것.
