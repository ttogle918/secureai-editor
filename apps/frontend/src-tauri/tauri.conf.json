{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SecureAI",
  "version": "0.1.0",
  "identifier": "io.secureai.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:desktop"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Korean"],
        "displayLanguageSelector": false
      },
      "wix": {
        "language": "1042"
      }
    },
    "linux": {},
    "macOS": {}
  },
  "app": {
    "windows": [
      {
        "title": "SecureAI — AI 보안 감사 에이전트",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
