FROM node:20-alpine AS builder

WORKDIR /app

COPY package.json ./
RUN npm install

COPY . .
RUN npm run build

FROM node:20-alpine

WORKDIR /app

COPY --from=builder /app/package.json ./
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/dist ./dist

# MCP Server usually runs on stdio or sse. 
# If running as a standalone service in docker, we might use SSE.
# For now, we'll just set it up so it can be run.
EXPOSE 3001

CMD ["npm", "run", "start"]
