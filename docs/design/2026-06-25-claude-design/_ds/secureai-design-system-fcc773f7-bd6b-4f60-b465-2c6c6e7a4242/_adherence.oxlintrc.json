{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "ui_kits/editor/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, JetBrains Mono."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--bg-0",
      "--bg-1",
      "--bg-2",
      "--bg-3",
      "--bg-4",
      "--border",
      "--border-2",
      "--border-alpha",
      "--critical",
      "--critical-dim",
      "--critical-glow",
      "--font-mono",
      "--font-sans",
      "--header-h",
      "--high",
      "--high-dim",
      "--info",
      "--info-dim",
      "--layer-config",
      "--layer-controller",
      "--layer-frontend",
      "--layer-repository",
      "--layer-service",
      "--low",
      "--low-dim",
      "--medium",
      "--medium-dim",
      "--orange",
      "--orange-2",
      "--orange-dim",
      "--orange-glow",
      "--orange-shadow",
      "--radius-full",
      "--radius-lg",
      "--radius-md",
      "--radius-sm",
      "--radius-xl",
      "--right-panel-w",
      "--sidebar-w",
      "--space-1",
      "--space-12",
      "--space-2",
      "--space-3",
      "--space-4",
      "--space-6",
      "--space-8",
      "--terminal-h",
      "--text-2xl",
      "--text-base",
