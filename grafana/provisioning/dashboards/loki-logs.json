        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{service=~\"secureai-.+\"} | trace_id=~\".+\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Trace ID 상관관계 (Backend + AI Engine 통합)",
      "type": "logs"
    }
