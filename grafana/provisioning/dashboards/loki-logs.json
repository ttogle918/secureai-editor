{
  "__inputs": [],
  "__requires": [
    {
      "type": "datasource",
      "id": "loki",
      "name": "Loki",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "SecureAI Engine — 서비스별 로그 집계 (Loki)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (service) (count_over_time({service=~\"secureai-.+\", level=\"ERROR\"}[5m]))",
          "legendFormat": "{{service}} ERROR",
          "refId": "A"
        }
      ],
      "title": "서비스별 ERROR 로그 (5분)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (service) (count_over_time({service=~\"secureai-.+\"}[5m]))",
          "legendFormat": "{{service}} 전체 로그량",
          "refId": "A"
        }
      ],
      "title": "서비스별 로그 총량 (5분)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "id": 12,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{service=\"secureai-backend\"} |= \"ERROR\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Backend ERROR 로그 (실시간)",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 18 },
      "id": 13,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{service=\"secureai-ai-engine\"} |= \"ERROR\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "AI Engine ERROR 로그 (실시간)",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "description": "trace_id로 Backend ↔ AI Engine 로그 상관관계 추적",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
